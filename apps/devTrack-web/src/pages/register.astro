---
import Bases from '../layouts/Base.astro';
const message = Astro.url.searchParams.get('message');
const error = Astro.url.searchParams.get('error');
---

<Bases title="Iniciar sesión">
  <main class="min-h-screen flex items-center justify-center p-4">
    <div class="w-full max-w-sm">
      <h1 class="text-lg font-medium tracking-tight">Dev Track</h1>
      <p class="text-xs text-[var(--color-text-muted)] mt-1">
        // sign up to continue
      </p>

      {
        message && (
          <p
            class="text-sm text-center text-green-700 bg-green-50 border border-green-200
                 rounded-lg px-4 py-2 mb-6"
          >
            {message}
          </p>
        )
      }

      {
        error && (
          <p
            class="text-sm text-center text-red-700 bg-green-50 border border-red-200
                 rounded-lg px-4 py-2 mb-6"
          >
            {error}
          </p>
        )
      }

      <form method="POST" action="/api/auth/signup" class="space-y-3 mb-4">
        <div>
          <label
            for="email"
            class="block text-xs text-[var(--color-text-muted)] mb-1.5"
            >email</label
          >
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            placeholder="you@domain.dev"
            class="w-full px-3 py-2 text-sm bg-[var(--color-surface)] border border-[var(--color-border)] rounded-md outline-none transition-colors placeholder:text-[var(--color-text-muted)]/50 focus:border-[var(--color-accent)] hover:border-[var(--color-text-muted)]/50"
          />
        </div>

        <div>
          <label
            for="name"
            class="block text-xs text-[var(--color-text-muted)] mb-1.5"
            >Nombre</label
          >
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="name"
            placeholder="Tu nombre"
            class="w-full px-3 py-2 text-sm bg-[var(--color-surface)] border border-[var(--color-border)] rounded-md outline-none transition-colors placeholder:text-[var(--color-text-muted)]/50 focus:border-[var(--color-accent)] hover:border-[var(--color-text-muted)]/50"
          />
        </div>

        <div>
          <label
            for="password"
            class="block text-xs text-[var(--color-text-muted)] mb-1.5"
            >password</label
          >
          <input
            type="password"
            id="password"
            name="password"
            required
            autocomplete="current-password"
            placeholder="••••••••"
            class="w-full px-3 py-2 text-sm bg-[var(--color-surface)] border border-[var(--color-border)] rounded-md outline-none transition-colors placeholder:text-[var(--color-text-muted)]/50 focus:border-[var(--color-accent)] hover:border-[var(--color-text-muted)]/50"
          />
        </div>
        <button
          type="submit"
          id="submit-btn"
          class="w-full mt-2 px-3 py-2 text-sm font-medium bg-[var(--color-text)] text-[var(--color-bg)] rounded-md transition-opacity hover:opacity-90 active:opacity-80 disabled:opacity-50 disabled:cursor-not-allowed"
        >
          <span id="btn-text">sign up()</span>
          <span
            id="btn-loading"
            class="hidden items-center justify-center gap-2"
          >
            <svg class="w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none">
              <circle
                class="opacity-25"
                cx="12"
                cy="12"
                r="10"
                stroke="currentColor"
                stroke-width="3"></circle>
              <path
                class="opacity-75"
                fill="currentColor"
                d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
              ></path>
            </svg>
            authenticating...
          </span>
        </button>
      </form>
      <!-- TODO: Add sign up with GitHub -->
      <!-- <div class="relative my-5">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-gray-200"></div>
        </div>
        <div class="relative flex justify-center">
          <span class="bg-gray-50 px-3 text-xs text-gray-400">o</span>
        </div>
      </div>

      <form method="POST" action="/api/auth/github">
        <button
          type="submit"
          class="w-full border border-gray-200 rounded-lg py-2 text-sm
               font-medium flex items-center justify-center gap-2"
        >
          Continuar con GitHub
        </button>
      </form> -->

      <p class="text-center text-sm text-gray-500 mt-6">
        ¿Ya tienes cuenta?
        <a
          href="/login"
          class="font-medium hover:text-[var(--color-text)] transition-colors"
          >Inicia sesión</a
        >
      </p>
    </div>
  </main>
</Bases>
